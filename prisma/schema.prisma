generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                Int       @id @default(autoincrement())
  name              String
  contact           String
  email             String?
  joiningDate       DateTime
  monthlyFee        Int
  status            String    @default("Active")
  totalMonthsPaid   Int       @default(0)
  holidayOffsetDays Int       @default(0)
  balanceAdjustment Int       @default(0)
  nextDueDate       DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  payments          Payment[]
}

model Payment {
  id            Int      @id @default(autoincrement())
  studentId     Int
  amountPaid    Int
  paymentDate   DateTime
  monthsCovered Int      @default(1)
  createdAt     DateTime @default(now())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  daysCount Int
  note      String?
  createdAt DateTime @default(now())
}
